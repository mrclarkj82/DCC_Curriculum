{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*-debug.log",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "predeploy": ["npm --prefix functions run build"]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
