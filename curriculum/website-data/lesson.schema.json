{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lesson Seed Data",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "programAreaId",
      "quarter",
      "unit",
      "lessonNumber",
      "title",
      "status",
      "video",
      "learningTarget",
      "bellRinger",
      "vocabulary",
      "slides",
      "assignment",
      "exitTicket",
      "tags"
    ],
    "properties": {
      "id": {
        "type": "string"
      },
      "programAreaId": {
        "type": "string"
      },
      "quarter": {
        "type": "string"
      },
      "unit": {
        "type": "string"
      },
      "lessonNumber": {
        "type": "integer"
      },
      "title": {
        "type": "string"
      },
      "status": {
        "type": "string"
      },
      "video": {
        "type": "object",
        "required": [
          "source",
          "start",
          "end",
          "url"
        ],
        "properties": {
          "source": {
            "type": "string"
          },
          "start": {
            "type": "string"
          },
          "end": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "learningTarget": {
        "type": "string"
      },
      "bellRinger": {
        "type": "object",
        "required": [
          "type",
          "prompt"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "vocabulary": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "term",
            "definition"
          ],
          "properties": {
            "term": {
              "type": "string"
            },
            "definition": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "slides": {
        "type": "object"
      },
      "assignment": {
        "type": "object"
      },
      "exitTicket": {
        "type": "string"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "additionalProperties": true
  }
}

