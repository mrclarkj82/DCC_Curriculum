{
  "name": "dcc-creative-studio",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:github-pages": "tsc -b && vite build --base=/dcccs/ && node scripts/prepare-github-pages.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "generate:block-calendar": "node scripts/generate-block-calendar.mjs",
    "validate:curriculum": "node scripts/validate-curriculum.mjs",
    "validate:hidden-frame": "node scripts/validate-hidden-frame-assets.mjs && node scripts/validate-hidden-frame-phase1.mjs && node scripts/validate-hidden-frame-phase2.mjs",
    "seed:curriculum": "node scripts/seedCurriculum.mjs",
    "seed:quizzes": "node scripts/seedQuizData.mjs"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.0.0",
    "firebase-admin": "^14.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.16"
  }
}
