rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Storage remains closed in Phase 5.
    // Assignment uploads, media submissions, portfolio files, and teacher review artifacts
    // will be opened with tightly scoped rules in a later upload phase.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

